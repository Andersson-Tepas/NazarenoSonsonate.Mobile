<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="NazarenoSonsonate.MobileNative.Views.MapaRecorridoPage"
             Title="Mapa del recorrido"
             BackgroundColor="#1a051d"
             NavigationPage.HasNavigationBar="False">

	<Grid RowDefinitions="Auto,*,Auto">

		<Grid BackgroundColor="#170318"
              Padding="20" ColumnDefinitions="*,Auto">

            <VerticalStackLayout Spacing="4">
                <Label x:Name="TituloLabel"
                       Text="Recorrido"
                       FontSize="26"
                       FontAttributes="Italic"
                       TextColor="#fcefd6" />

                <Label x:Name="EstadoLabel"
                       Text="UBICACI�N EN VIVO"
                       FontSize="11"
                       TextColor="#9d759b" />
            </VerticalStackLayout>

            <Label Grid.Column="1"
                   Text="EN VIVO"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="#fcefd6"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Map -->
        <Grid Grid.Row="1">
            <maps:Map x:Name="Mapa"
                      IsShowingUser="False" />

            <Frame x:Name="OverlayFrame"
                   IsVisible="False"
                   BackgroundColor="#E62B002A"
                   BorderColor="#33FCEFD6"
                   Padding="20"
                   CornerRadius="12"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Label x:Name="OverlayLabel"
                       TextColor="#fcefd6"
                       HorizontalTextAlignment="Center" />
            </Frame>
        </Grid>

        <!-- Bottom nav -->
        <Grid Grid.Row="2"
              BackgroundColor="#170318"
              Padding="10,10,10,25"
              ColumnDefinitions="*,*,*,*,*">

            <Button Text="Procesi�n"
                    Grid.Column="0"
                    Clicked="OnProcesionClicked"
                    BackgroundColor="#3b0939"
                    TextColor="#fcefd6" />

            <Button Text="Mi ubicaci�n"
                    Grid.Column="1"
                    Clicked="OnMiUbicacionClicked"
                    BackgroundColor="Transparent"
                    TextColor="#7a5278" />

            <Button Text="Cargador"
                    Grid.Column="2"
                    Clicked="OnCargadorClicked"
                    BackgroundColor="Transparent"
                    TextColor="#7a5278" />

            <Button Text="Cargadora"
                    Grid.Column="3"
                    Clicked="OnCargadoraClicked"
                    BackgroundColor="Transparent"
                    TextColor="#7a5278" />

            <Button Text="Grupos"
                    Grid.Column="4"
                    Clicked="OnGruposClicked"
                    BackgroundColor="Transparent"
                    TextColor="#7a5278" />
        </Grid>
    </Grid>
</ContentPage>