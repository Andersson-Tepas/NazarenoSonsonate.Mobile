<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NazarenoSonsonate.MobileNative.Views.SplashPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#1a0624">

    <Grid Padding="24">

        <Frame HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="350"
               HeightRequest="650"
               BackgroundColor="#3b0939"
               BorderColor="#6a2b7c"
               CornerRadius="0"
               HasShadow="True"
               Padding="0">

            <Grid Padding="20"
                  RowDefinitions="Auto,*,Auto">

                <!-- Esquinas decorativas -->
                <BoxView HorizontalOptions="Start"
                         VerticalOptions="Start"
                         WidthRequest="40"
                         HeightRequest="1"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="Start"
                         VerticalOptions="Start"
                         WidthRequest="1"
                         HeightRequest="40"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="End"
                         VerticalOptions="Start"
                         WidthRequest="40"
                         HeightRequest="1"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="End"
                         VerticalOptions="Start"
                         WidthRequest="1"
                         HeightRequest="40"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="Start"
                         VerticalOptions="End"
                         WidthRequest="40"
                         HeightRequest="1"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="Start"
                         VerticalOptions="End"
                         WidthRequest="1"
                         HeightRequest="40"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="End"
                         VerticalOptions="End"
                         WidthRequest="40"
                         HeightRequest="1"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <BoxView HorizontalOptions="End"
                         VerticalOptions="End"
                         WidthRequest="1"
                         HeightRequest="40"
                         Color="#55FFFFFF"
                         Margin="0,0,0,0" />

                <!-- Encabezado -->
                <VerticalStackLayout Grid.Row="0"
                                     Margin="0,36,0,0"
                                     Spacing="12"
                                     HorizontalOptions="Center">

                    <Label Text="Asociación Hermandad de"
                           FontSize="14"
                           TextTransform="Uppercase"
                           TextColor="#F5E8D6"
                           HorizontalTextAlignment="Center" />

                    <VerticalStackLayout Spacing="-4">
                        <Label Text="JESÚS DE"
                               FontSize="44"
                               TextColor="#FFF7EA"
                               HorizontalTextAlignment="Center"
                               FontFamily="Times New Roman" />

                        <Label Text="Nazareno"
                               FontSize="50"
                               TextColor="#E2C07D"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Italic"
                               TextTransform="Uppercase"
                               FontFamily="Times New Roman" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Centro -->
                <Grid Grid.Row="1"
                      HorizontalOptions="Center"
                      VerticalOptions="Center"
                      WidthRequest="220"
                      HeightRequest="220">

                    <Frame BackgroundColor="Black"
                           BorderColor="#22FFFFFF"
                           CornerRadius="0"
                           Padding="0"
                           HasShadow="False"
                           WidthRequest="220"
                           HeightRequest="220"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">

                        <Grid>
                            <BoxView Color="#4f2500" />
                            <Image Source="logo-insta.jpg"
                                   WidthRequest="110"
                                   HeightRequest="110"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </Grid>

                <!-- Pie -->
                <VerticalStackLayout Grid.Row="2"
                                     Margin="0,0,0,28"
                                     Spacing="20"
                                     HorizontalOptions="Center">

                    <BoxView WidthRequest="1"
                             HeightRequest="60"
                             Color="#E2C07D"
                             HorizontalOptions="Center" />

                    <Label Text="Fundada en 1875"
                           FontSize="12"
                           TextTransform="Uppercase"
                           TextColor="#E2C07D"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Frame>
    </Grid>
</ContentPage>