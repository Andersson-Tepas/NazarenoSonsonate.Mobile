@page "/splashscreen"
@inject NavigationManager Navigation

<style>
    .splash-container {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        background: radial-gradient(circle at center, #260a29 0%, #120114 80%, #0d000e 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        z-index: 2000;
        padding: 24px;
    }

    .logo-glow-border {
        width: 180px;
        height: 180px;
        background: linear-gradient(135deg, #ffffff 0%, #a980ad 50%, #ffdf85 100%);
        border-radius: 18px;
        padding: 4px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
    }

    .logo-inner-bg {
        background-color: #000000;
        width: 100%;
        height: 100%;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .logo-inner-bg img {
            width: 130px;
            max-width: 100%;
            height: auto;
            object-fit: contain;
        }

    .sacra-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 24px;
    }

    .sacra-text {
        color: #b5907a;
        font-size: 11px;
        letter-spacing: 4px;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .sacra-line {
        width: 44px;
        height: 1px;
        background-color: #7a5c4e;
    }

    .main-title {
        color: #fcefd6;
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-size: 28px;
        font-weight: 700;
        text-align: center;
        line-height: 1.3;
        margin: 0 16px 16px;
        text-wrap: balance;
        max-width: 340px;
    }

    .subtitle {
        color: #9d759b;
        font-style: italic;
        font-size: 15px;
        text-align: center;
        margin: 0 0 52px 0;
        max-width: 320px;
    }

    .year-section {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .year-text {
        color: #e5b310;
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-size: 24px;
        font-weight: 700;
        letter-spacing: 2px;
    }

    .year-icon {
        width: 16px;
        height: 16px;
        fill: #e5b310;
        flex-shrink: 0;
    }

    .bottom-line {
        width: 1px;
        height: 42px;
        background: linear-gradient(to bottom, #7a5c4e 0%, transparent 100%);
    }

    @@media (max-width: 420px) {
        .logo-glow-border {
            width: 160px;
            height: 160px;
            margin-bottom: 34px;
        }

        .logo-inner-bg img {
            width: 115px;
        }

        .main-title {
            font-size: 24px;
        }

        .subtitle {
            font-size: 14px;
            margin-bottom: 44px;
        }

        .year-text {
            font-size: 22px;
        }
    }
</style>

<div class="splash-container">
    <div class="logo-glow-border">
        <div class="logo-inner-bg">
            <img src="logo-insta.jpg" alt="AHJN Logo" />
        </div>
    </div>

    <h1 class="main-title">
        Asociación Hermandad<br />
        de Jesús Nazareno de<br />
        Sonsonate
    </h1>

    <p class="subtitle">Consagrando siglos de fe y tradición</p>

    <div class="year-section">
        <svg class="year-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 16H8V4h12v14z" />
        </svg>

        <span class="year-text">1875</span>

        <svg class="year-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 16H8V4h12v14z" />
        </svg>
    </div>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(5200);
        Navigation.NavigateTo("/recorridos", replace: true);
    }
}