@page "/splashscreen"
@inject NavigationManager Navigation

<style>
    .splash-wrapper {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        background-color: #1a0624;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        box-sizing: border-box;
        overflow: hidden;
        z-index: 2000;
        font-family: 'Times New Roman', Times, serif;
    }

    .card {
        width: min(350px, 100%);
        height: min(650px, calc(100vh - 48px));
        background: radial-gradient(circle, #5e1a84 0%, #1a0624 80%);
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        padding: 40px 20px;
        box-sizing: border-box;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        text-align: center;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
    }

    .corner {
        position: absolute;
        width: 40px;
        height: 40px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .top-left {
        top: 20px;
        left: 20px;
        border-right: none;
        border-bottom: none;
    }

    .top-right {
        top: 20px;
        right: 20px;
        border-left: none;
        border-bottom: none;
    }

    .bottom-left {
        bottom: 20px;
        left: 20px;
        border-right: none;
        border-top: none;
    }

    .bottom-right {
        bottom: 20px;
        right: 20px;
        border-left: none;
        border-top: none;
    }

    .header-block {
        margin-top: 36px;
    }

    .header-text {
        font-size: 14px;
        letter-spacing: 4px;
        text-transform: uppercase;
        opacity: 0.85;
        margin-bottom: 12px;
        color: #f5e8d6;
    }

    .main-title {
        margin-top: 10px;
    }

        .main-title h1 {
            font-size: 45px;
            margin: 0;
            font-weight: normal;
            line-height: 0.95;
            letter-spacing: 2px;
            color: #fff7ea;
        }

        .main-title h2 {
            font-size: 50px;
            margin: 0;
            font-style: italic;
            color: #e2c07d;
            font-weight: normal;
            letter-spacing: 1px;
            text-transform: uppercase;
            line-height: 1;
        }

    .image-container {
        width: 220px;
        height: 220px;
        background: #000;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 0 50px rgba(226, 192, 125, 0.18);
        border: 1px solid rgba(255,255,255,0.06);
        overflow: hidden;
        position: relative;
    }

    .sunburst {
        width: 100%;
        height: 100%;
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, #fff7dc 0%, #ffca63 8%, #ff8c00 16%, #6a2b00 26%, #000 72%);
    }

        .sunburst::before {
            content: "";
            position: absolute;
            inset: 0;
            background: repeating-conic-gradient( from 0deg, rgba(255, 204, 102, 0.95) 0deg 3deg, rgba(0, 0, 0, 0) 3deg 12deg );
            mix-blend-mode: screen;
            opacity: 0.45;
        }

        .sunburst::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, transparent 0%, transparent 28%, rgba(0,0,0,0.65) 78%, rgba(0,0,0,1) 100%);
        }

    .shield-logo {
        position: relative;
        z-index: 2;
        width: 110px;
        height: 110px;
        object-fit: contain;
        filter: drop-shadow(0 0 12px rgba(255, 200, 90, 0.35));
    }

    .footer-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 28px;
    }

    .divider {
        width: 1px;
        height: 60px;
        background: linear-gradient(to bottom, transparent, #e2c07d, transparent);
        margin-bottom: 20px;
    }

    .footer-text {
        font-size: 12px;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: #e2c07d;
    }

    @@media (max-width: 420px) {
        .card {
            padding: 34px 18px;
            height: min(620px, calc(100vh - 32px));
        }

        .header-text {
            font-size: 12px;
            letter-spacing: 3px;
        }

        .main-title h1 {
            font-size: 36px;
        }

        .main-title h2 {
            font-size: 42px;
        }

        .image-container {
            width: 190px;
            height: 190px;
        }

        .shield-logo {
            width: 95px;
            height: 95px;
        }

        .footer-text {
            font-size: 11px;
            letter-spacing: 4px;
        }
    }
</style>

<div class="splash-wrapper">
    <div class="card">
        <div class="corner top-left"></div>
        <div class="corner top-right"></div>
        <div class="corner bottom-left"></div>
        <div class="corner bottom-right"></div>

        <div class="header-block">
            <div class="header-text">Asociación Hermandad de</div>

            <div class="main-title">
                <h1>JESÚS DE</h1>
                <h2>Nazareno</h2>
            </div>
        </div>

        <div class="image-container">
            <div class="sunburst"></div>
            <img class="shield-logo" src="logo-insta.jpg" alt="Escudo Nazareno" />
        </div>

        <div class="footer-block">
            <div class="divider"></div>
            <div class="footer-text">Fundada en 1875</div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(5200);
        Navigation.NavigateTo("/recorridos", replace: true);
    }
}