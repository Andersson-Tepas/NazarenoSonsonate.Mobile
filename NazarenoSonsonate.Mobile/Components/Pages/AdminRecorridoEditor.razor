@page "/admin/recorrido-editor/{Id:int}"
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject NavigationManager Navigation

<h3>Editor de recorrido @Id</h3>

<div id="mapa-admin" style="height: 500px; width: 100%; border-radius: 12px;"></div>

<div class="mt-3 d-flex gap-2">
    <button class="btn btn-primary" @onclick="GuardarRuta">
        Guardar ruta
    </button>

    <button class="btn btn-secondary" @onclick="VolverARecorridos">
        Volver a recorridos
    </button>
</div>

<p class="mt-3">@mensaje</p>

@code {
    [Parameter]
    public int Id { get; set; }

    private string? mensaje;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("mapaRecorridoAdmin.init", "mapa-admin", 13.7189, -89.7242, 16);
        }
    }

    private async Task GuardarRuta()
    {
        var geoJson = await JS.InvokeAsync<object>("mapaRecorridoAdmin.getGeoJson");
        var texto = System.Text.Json.JsonSerializer.Serialize(geoJson);

        await RecorridoService.GuardarRutaAsync(Id, texto);
        mensaje = "Ruta guardada correctamente.";

        await Task.Delay(800);
        Navigation.NavigateTo("/recorridos");
    }

    private void VolverARecorridos()
    {
        Navigation.NavigateTo("/recorridos");
    }
}