@page "/admin/recorrido-editor/{Id:int}"
@using System.Text.Json
@using Microsoft.JSInterop
@using NazarenoSonsonate.Shared.DTOs
@inject IJSRuntime JS
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject NazarenoSonsonate.Mobile.Services.PuntoRutaCacheService PuntoRutaCacheService
@inject NazarenoSonsonate.Mobile.Services.UbicacionTrackingService TrackingService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<style>
    .editor-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #120516;
        display: flex;
        flex-direction: column;
        gap: 15px;
        z-index: 1000;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px 15px;
        overflow-y: auto;
        box-sizing: border-box;
    }

    .editor-container {
        background-color: #120516;
        min-height: 100vh;
        color: white;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 20px 15px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .header-icon {
        width: 24px;
        height: 24px;
        fill: #cbb4d6;
        cursor: pointer;
    }

    .header-title {
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-style: italic;
        font-size: 20px;
        color: #e6d3f0;
        margin: 0;
    }

    .info-card {
        background-color: #211029;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    .card-title {
        color: #f0c579;
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-style: italic;
        font-size: 28px;
        margin: 0 0 10px 0;
    }

    .card-subtitle {
        color: #cbb4d6;
        font-size: 14px;
        margin-bottom: 15px;
    }

    .time-badge {
        background-color: #381c47;
        color: #d6bdec;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .instruction-text {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #9d7c8e;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .map-container {
        border-radius: 16px;
        width: 100%;
        flex-grow: 1;
        min-height: 350px;
        border: 2px solid #381c47;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.4);
    }

    .tracking-card {
        background-color: #211029;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .tracking-title {
        color: #f0c579;
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-style: italic;
        font-size: 24px;
        margin: 0;
    }

    .tracking-subtitle {
        color: #cbb4d6;
        font-size: 13px;
        margin: 0;
    }

    .tracking-row {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .tracking-label {
        font-size: 12px;
        color: #d6bdec;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
    }

    .tracking-select {
        width: 100%;
        border: 1px solid #5c2f73;
        border-radius: 12px;
        background-color: #170318;
        color: #fcefd6;
        padding: 14px;
        font-size: 15px;
        outline: none;
    }

    .tracking-status-box {
        background-color: #170318;
        border: 1px solid #3f204f;
        border-radius: 12px;
        padding: 14px;
        display: grid;
        gap: 8px;
    }

    .tracking-status-line {
        font-size: 13px;
        color: #fcefd6;
    }

    .tracking-status-value {
        font-weight: 700;
        color: #f0c579;
    }

    .tracking-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .btn-track-start {
        background-color: #1f8f4e;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
    }

    .btn-track-stop {
        background-color: #8f1f2d;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
    }

        .btn-track-start:disabled,
        .btn-track-stop:disabled,
        .tracking-select:disabled {
            opacity: 0.55;
            cursor: not-allowed;
        }

    .action-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .btn-action {
        border-radius: 12px;
        border: none;
        padding: 15px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: 11px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        min-height: 80px;
        transition: transform 0.1s ease;
    }

        .btn-action:active {
            transform: scale(0.95);
        }

    .btn-full-width {
        grid-column: span 2;
    }

    .bg-purple {
        background-color: #4c1d95;
        color: white;
    }

    .bg-dark-purple {
        background-color: #211029;
        color: #e5ccb3;
    }

    .btn-save {
        background-color: #ffb703;
        color: #452100;
        border: none;
        border-radius: 12px;
        padding: 18px;
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-style: italic;
        font-size: 18px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        margin-top: 5px;
        cursor: pointer;
    }

    .footer-close {
        text-align: center;
        color: #9d7c8e;
        font-size: 12px;
        letter-spacing: 2px;
        margin-top: 10px;
        margin-bottom: 20px;
        text-transform: uppercase;
        cursor: pointer;
    }

    .status-message {
        text-align: center;
        padding: 15px;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 10px;
    }

    .msg-loading {
        background-color: #211029;
        color: #cbb4d6;
    }

    .msg-error {
        background-color: #4a0000;
        color: #ffb3b3;
    }

    .msg-success {
        background-color: #003314;
        color: #99ffbb;
    }
</style>

<div class="editor-container">

    @if (cargando)
    {
        <div class="status-message msg-loading">
            Cargando recorrido...
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="status-message msg-error">
            @error
        </div>
        <div class="footer-close" @onclick="VolverARecorridos">X VOLVER</div>
    }
    else if (recorrido is null)
    {
        <div class="status-message msg-error">
            No se encontró el recorrido.
        </div>
        <div class="footer-close" @onclick="VolverARecorridos">X VOLVER</div>
    }
    else
    {
        <div class="top-header">
            <svg class="header-icon" viewBox="0 0 24 24" @onclick="VolverARecorridos">
                <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
            </svg>
            <h2 class="header-title">@recorrido.Nombre</h2>
            <div style="width: 24px;"></div>
        </div>

        <div class="info-card">
            <h1 class="card-title">@recorrido.Nombre</h1>
            <p class="card-subtitle">@recorrido.Descripcion</p>

            <div class="time-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                </svg>
                Hora de salida: @recorrido.HoraSalida
            </div>

            <div class="instruction-text">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 11.24V7.5C9 6.12 10.12 5 11.5 5S14 6.12 14 7.5v3.74c1.21-.81 2-2.18 2-3.74C16 5.01 13.99 3 11.5 3S7 5.01 7 7.5c0 1.56.79 2.93 2 3.74zm9.84 4.63l-4.54-2.26c-.17-.07-.35-.11-.54-.11H13v-6c0-.83-.67-1.5-1.5-1.5S10 6.67 10 7.5v10.74l-3.43-.72c-.08-.01-.15-.03-.24-.03-.31 0-.59.13-.79.33l-.79.8 4.94 4.94c.27.27.65.44 1.04.44h6.79c.75 0 1.33-.55 1.44-1.28l.75-5.27c.01-.07.02-.14.02-.2 0-.62-.38-1.16-.91-1.38z" />
                </svg>
                Toca el mapa para definir los puntos de la ruta
            </div>
        </div>

        <div id="mapa-admin" class="map-container"></div>

        <div class="tracking-card">
            <h3 class="tracking-title">Rastreo en vivo</h3>
            <p class="tracking-subtitle">Desde aquí iniciás el envío GPS del anda seleccionada cada 5 segundos.</p>

            <div class="tracking-row">
                <label class="tracking-label">Unidad procesional</label>
                <select class="tracking-select" @bind="tipoUnidadSeleccionada" disabled="@rastreoActivo">
                    <option value="JesusNazareno">Anda Jesús Nazareno</option>
                    <option value="VirgenMaria">Anda Virgen María</option>
                </select>
            </div>

            <div class="tracking-status-box">
                <div class="tracking-status-line">
                    Estado:
                    <span class="tracking-status-value">@estadoRastreo</span>
                </div>

                <div class="tracking-status-line">
                    Unidad activa:
                    <span class="tracking-status-value">@ObtenerNombreUnidad(tipoUnidadSeleccionada)</span>
                </div>

                <div class="tracking-status-line">
                    Último envío:
                    <span class="tracking-status-value">@ultimaHoraEnvioTexto</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorRastreo))
                {
                    <div class="tracking-status-line" style="color:#ffb3b3;">
                        @errorRastreo
                    </div>
                }
            </div>

            <div class="tracking-actions">
                <button class="btn-track-start"
                        @onclick="IniciarRastreo"
                        disabled="@rastreoActivo">
                    Iniciar rastreo
                </button>

                <button class="btn-track-stop"
                        @onclick="DetenerRastreo"
                        disabled="@(!rastreoActivo)">
                    Detener rastreo
                </button>
            </div>
        </div>

        <div class="action-grid">
            <button class="btn-action btn-full-width bg-purple" @onclick="ActivarCheckpoint">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C8.14 2 5 5.14 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.86-3.14-7-7-7zm-1 5h2v2h2v2h-2v2h-2v-2H9v-2h2V7z" />
                </svg>
                Agregar chibolita
            </button>

            <button class="btn-action bg-dark-purple" @onclick="EditarRutaJesus">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#cbb4d6">
                    <circle cx="12" cy="12" r="8"></circle>
                </svg>
                Editar ruta Jesús
            </button>

            <button class="btn-action bg-dark-purple" @onclick="EditarRutaVirgen">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#f0c579">
                    <path d="M12 2L13.8 8.2L20 10L13.8 11.8L12 18L10.2 11.8L4 10L10.2 8.2L12 2z" />
                </svg>
                Editar ruta Virgen
            </button>

            <button class="btn-action bg-dark-purple" @onclick="DeshacerUltimoPunto">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#f0c579">
                    <path d="M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z" />
                </svg>
                Deshacer último punto
            </button>

            <button class="btn-action bg-dark-purple" @onclick="LimpiarRutaActiva">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#f0c579">
                    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                </svg>
                Limpiar ruta activa
            </button>

            <button class="btn-action bg-dark-purple" @onclick="LimpiarCheckpoints">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#cbb4d6">
                    <path d="M12 2C8.14 2 5 5.14 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.86-3.14-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                    <line x1="4" y1="4" x2="20" y2="20" stroke="#cbb4d6" stroke-width="2" />
                </svg>
                Limpiar chibolitas
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(mensaje))
        {
            <div class="status-message msg-success">
                @mensaje
            </div>
        }

        <button class="btn-save" @onclick="GuardarMapa">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" />
            </svg>
            Guardar ruta y puntos
        </button>

        <div class="footer-close" @onclick="VolverARecorridos">
            X VOLVER
        </div>
    }

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private RecorridoDto? recorrido;
    private bool cargando = true;
    private string? error;
    private string? mensaje;
    private bool mapaInicializado;
    private bool dependenciasMapaCargadas;
    private List<PuntoRutaDto> puntosRutaCache = new();

    private string tipoUnidadSeleccionada = "JesusNazareno";

    private bool rastreoActivo => TrackingService.IsTracking;
    private string estadoRastreo => TrackingService.Estado;
    private string? errorRastreo => TrackingService.Error;
    private DateTime? ultimaHoraEnvio => TrackingService.UltimaHoraEnvio;
    private double? ultimaPrecisionMetros => TrackingService.UltimaPrecisionMetros;

    private string ultimaHoraEnvioTexto => ultimaHoraEnvio?.ToString("g") ?? "Sin envíos todavía";

    private string precisionGpsTexto =>
        ultimaPrecisionMetros.HasValue
            ? $"{ultimaPrecisionMetros.Value:0} m"
            : "Esperando lectura GPS";

    protected override void OnInitialized()
    {
        TrackingService.OnStateChanged += TrackingStateChanged;
    }

    private void TrackingStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;
            error = null;
            mensaje = null;
            mapaInicializado = false;

            recorrido = await RecorridoService.ObtenerRecorridoPorIdAsync(Id);

            var puntosDetalle = recorrido?.PuntosRuta?.ToList() ?? new List<PuntoRutaDto>();

            if (puntosDetalle.Count > 0)
            {
                puntosRutaCache = puntosDetalle;
                await PuntoRutaCacheService.GuardarPuntosPorRecorridoAsync(Id, puntosRutaCache);
            }
            else
            {
                puntosRutaCache = await PuntoRutaCacheService.ObtenerPuntosPorRecorridoAsync(
                    Id,
                    forzarRecarga: false,
                    permitirApi: true);
            }

            if (recorrido is not null)
            {
                recorrido.PuntosRuta = puntosRutaCache;
            }

            if (TrackingService.IsTracking && TrackingService.RecorridoId == Id)
            {
                tipoUnidadSeleccionada = TrackingService.TipoUnidad;
            }
        }
        catch (Exception ex)
        {
            error = $"Error al cargar recorrido: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!cargando && !mapaInicializado && recorrido is not null)
        {
            try
            {
                await CargarDependenciasMapaAdminAsync();

                var checkpointsJson = JsonSerializer.Serialize(puntosRutaCache);

                await JS.InvokeVoidAsync("mapaRecorridoAdmin.esperarGoogleMaps");
                await JS.InvokeVoidAsync(
                    "mapaRecorridoAdmin.init",
                    "mapa-admin",
                    13.7189,
                    -89.7242,
                    16,
                    recorrido.RutaGeoJson,
                    checkpointsJson);

                mapaInicializado = true;
            }
            catch (Exception ex)
            {
                error = $"Error al inicializar mapa: {ex.Message}";
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task CargarDependenciasMapaAdminAsync()
    {
        if (dependenciasMapaCargadas)
            return;

        var googleMapsUrl = "https://maps.googleapis.com/maps/api/js?key=AIzaSyBfVQADIjXfJSWGD-14tz4cuLfc8Pv8pcA&loading=async&callback=nazarenoGoogleMapsLoaded";

        var script = $@"
(async function () {{
    window.googleMapsReady = window.googleMapsReady || false;
    window.nazarenoGoogleMapsLoaded = window.nazarenoGoogleMapsLoaded || function () {{
        window.googleMapsReady = true;
    }};

    function loadScript(src, id) {{
        return new Promise(function (resolve, reject) {{
            if (document.getElementById(id)) {{
                resolve();
                return;
            }}

            var script = document.createElement('script');
            script.id = id;
            script.src = src;
            script.async = true;
            script.defer = true;
            script.onload = function () {{ resolve(); }};
            script.onerror = function () {{ reject(new Error('No se pudo cargar ' + src)); }};
            document.body.appendChild(script);
        }});
    }}

    if (!window.google || !window.google.maps) {{
        await loadScript('{googleMapsUrl}', 'google-maps-js');
    }} else {{
        window.googleMapsReady = true;
    }}

    await loadScript('js/mapaRecorridoAdmin.js', 'mapa-recorrido-admin-js');
}})();
";

        await JS.InvokeVoidAsync("eval", script);
        dependenciasMapaCargadas = true;
    }

    private async Task ActivarCheckpoint()
    {
        await JS.InvokeVoidAsync("mapaRecorridoAdmin.activarModoCheckpoint");
        mensaje = "Toca el mapa para agregar la chibolita.";
    }

    private async Task EditarRutaJesus()
    {
        await JS.InvokeVoidAsync("mapaRecorridoAdmin.seleccionarRutaJesus");
        mensaje = "Ahora estás editando la ruta de Jesús en morado.";
    }

    private async Task EditarRutaVirgen()
    {
        await JS.InvokeVoidAsync("mapaRecorridoAdmin.seleccionarRutaVirgen");
        mensaje = "Ahora estás editando la ruta de la Virgen en amarillo.";
    }

    private async Task DeshacerUltimoPunto()
    {
        await JS.InvokeVoidAsync("mapaRecorridoAdmin.deshacerUltimoPunto");
    }

    private async Task LimpiarRutaActiva()
    {
        await JS.InvokeVoidAsync("mapaRecorridoAdmin.limpiarRutaActiva");
    }

    private async Task LimpiarCheckpoints()
    {
        await JS.InvokeVoidAsync("mapaRecorridoAdmin.limpiarCheckpoints");
    }

    private async Task GuardarMapa()
    {
        try
        {
            var geoJsonObj = await JS.InvokeAsync<object>("mapaRecorridoAdmin.getGeoJson");
            var checkpointsObj = await JS.InvokeAsync<object>("mapaRecorridoAdmin.getCheckpoints");

            var options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

            var dto = new GuardarMapaRecorridoDto
            {
                RutaGeoJson = JsonSerializer.Serialize(geoJsonObj),
                PuntosRuta = JsonSerializer.Deserialize<List<PuntoRutaDto>>(
                    JsonSerializer.Serialize(checkpointsObj), options) ?? new()
            };

            foreach (var punto in dto.PuntosRuta)
            {
                punto.RecorridoId = Id;
            }

            await RecorridoService.GuardarMapaAsync(Id, dto);

            puntosRutaCache = dto.PuntosRuta ?? new List<PuntoRutaDto>();
            await PuntoRutaCacheService.GuardarPuntosPorRecorridoAsync(Id, puntosRutaCache);

            if (recorrido is not null)
            {
                recorrido.PuntosRuta = puntosRutaCache;
                recorrido.RutaGeoJson = dto.RutaGeoJson;
            }

            mensaje = "Ruta y puntos guardados correctamente.";
        }
        catch (Exception ex)
        {
            mensaje = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task IniciarRastreo()
    {
        await TrackingService.StartAsync(Id, tipoUnidadSeleccionada);
    }

    private async Task DetenerRastreo()
    {
        await TrackingService.StopAsync();
    }

    private string ObtenerNombreUnidad(string tipoUnidad)
    {
        return tipoUnidad == "VirgenMaria"
            ? "Anda Virgen María"
            : "Anda Jesús Nazareno";
    }

    private void VolverARecorridos()
    {
        Navigation.NavigateTo("/recorridos");
    }

    public async ValueTask DisposeAsync()
    {
        TrackingService.OnStateChanged -= TrackingStateChanged;

        if (dependenciasMapaCargadas)
        {
            try
            {
                await JS.InvokeVoidAsync("mapaRecorridoAdmin.dispose");
            }
            catch
            {
            }
        }
    }
}