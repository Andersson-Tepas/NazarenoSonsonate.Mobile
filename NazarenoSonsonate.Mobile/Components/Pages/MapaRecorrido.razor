@page "/mapa-recorrido/{Id:int}"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.Devices.Sensors
@using NazarenoSonsonate.Shared.DTOs
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject IJSRuntime JS
@inject HttpClient Http
@implements IAsyncDisposable

<style>
    .map-fullscreen-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #1a051d;
        display: flex;
        flex-direction: column;
        z-index: 1000;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .map-header {
        width: 100%;
        padding: 45px 20px 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 10;
        background-color: #170318;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

    .header-titles {
        display: flex;
        flex-direction: column;
    }

    .main-title {
        font-size: 26px;
        font-family: Georgia, serif;
        font-style: italic;
        color: #fcefd6;
        margin: 0 0 4px 0;
    }

    .subtitle {
        font-size: 11px;
        color: #9d759b;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
    }

    .live-badge {
        font-size: 12px;
        color: #fcefd6;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .map-view {
        flex-grow: 1;
        width: 100%;
        height: 100%;
        position: relative;
    }

    #mapa-recorrido {
        width: 100%;
        height: 100%;
    }

    .status-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: rgba(43, 0, 42, 0.9);
        padding: 20px;
        border-radius: 12px;
        color: #fcefd6;
        text-align: center;
        z-index: 20;
        border: 1px solid rgba(252, 239, 214, 0.2);
    }

    .bottom-nav {
        background-color: #170318;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 5px 25px 5px;
        box-shadow: 0 -5px 20px rgba(0,0,0,0.5);
        z-index: 10;
    }

    .nav-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px 0;
        color: #7a5278;
        cursor: pointer;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .nav-item.active {
            background-color: #3b0939;
            color: #fcefd6;
        }

    .nav-icon {
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .nav-icon svg {
            width: 22px;
            height: 22px;
            fill: currentColor;
        }

    .nav-text {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        text-align: center;
    }
</style>

<div class="map-fullscreen-container">

    <header class="map-header">
        <div class="header-titles">
            <h1 class="main-title">@recorrido?.Nombre</h1>
            <span class="subtitle">@estadoTiempoReal</span>
        </div>
        <div class="live-badge">EN VIVO</div>
    </header>

    <div class="map-view">

        @if (cargando)
        {
            <div class="status-overlay">Cargando recorrido...</div>
        }
        else if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="status-overlay" style="color: #ff6b6b;">@error</div>
        }
        else if (recorrido is null)
        {
            <div class="status-overlay">No se encontró el recorrido.</div>
        }
        else if (string.IsNullOrWhiteSpace(recorrido.RutaGeoJson))
        {
            <div class="status-overlay">Recorrido pendiente de publicación.</div>
        }
        else
        {
            <div id="mapa-recorrido"></div>
        }
    </div>

    <nav class="bottom-nav">
        <div class="nav-item active">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" />
                    <circle cx="12" cy="12" r="4" fill="currentColor" />
                </svg>
            </div>
            <span class="nav-text">Procesión</span>
        </div>

        <div class="nav-item" @onclick="MostrarMiUbicacion">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" fill="none" stroke="currentColor" stroke-width="2" />
                    <circle cx="12" cy="10" r="3" fill="currentColor" />
                </svg>
            </div>
            <span class="nav-text">Mi ubicación</span>
        </div>

        <div class="nav-item">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" fill="none" stroke="currentColor" stroke-width="2" />
                    <circle cx="12" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2" />
                </svg>
            </div>
            <span class="nav-text">Cargador</span>
        </div>

        <div class="nav-item">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" fill="none" stroke="currentColor" stroke-width="2" />
                    <path d="M12 3a4 4 0 0 0-4 4v1a4 4 0 0 0 8 0V7a4 4 0 0 0-4-4z" fill="none" stroke="currentColor" stroke-width="2" />
                </svg>
            </div>
            <span class="nav-text">Cargadora</span>
        </div>

        <div class="nav-item">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" fill="none" stroke="currentColor" stroke-width="2" />
                    <circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" fill="none" stroke="currentColor" stroke-width="2" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" fill="none" stroke="currentColor" stroke-width="2" />
                </svg>
            </div>
            <span class="nav-text">Grupos</span>
        </div>
    </nav>

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private RecorridoDto? recorrido;
    private bool cargando = true;
    private string? error;
    private bool mapaDibujado;
    private HubConnection? hubConnection;
    private string estadoTiempoReal = "UBICACIÓN EN VIVO";

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;
            error = null;
            mapaDibujado = false;
            estadoTiempoReal = "UBICACIÓN EN VIVO";

            if (hubConnection is not null)
            {
                await hubConnection.DisposeAsync();
                hubConnection = null;
            }

            recorrido = await RecorridoService.ObtenerRecorridoPorIdAsync(Id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!cargando &&
            !mapaDibujado &&
            recorrido is not null &&
            !string.IsNullOrWhiteSpace(recorrido.RutaGeoJson))
        {
            await JS.InvokeVoidAsync("mapaRecorrido.esperarGoogleMaps");
            await JS.InvokeVoidAsync("mapaRecorrido.init", "mapa-recorrido", 13.7189, -89.7242, 16);
            await JS.InvokeVoidAsync("mapaRecorrido.drawGeoJson", recorrido.RutaGeoJson);

            await IniciarTiempoReal();

            mapaDibujado = true;
        }
    }

    private async Task IniciarTiempoReal()
    {
        if (Http.BaseAddress is null)
        {
            estadoTiempoReal = "No se pudo resolver la URL de la API.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var hubUrl = new Uri(Http.BaseAddress, "hubs/procesion");

        hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl.ToString())
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<UbicacionProcesionDto>("UbicacionActualizada", async dto =>
        {
            if (dto.RecorridoId != Id)
                return;

            await JS.InvokeVoidAsync(
                "mapaRecorrido.actualizarMarcadorTiempoReal",
                dto.Latitud,
                dto.Longitud,
                dto.GrupoActual ?? "",
                dto.Mensaje ?? "",
                dto.FechaHora.ToString("g"));
        });

        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("UnirseRecorrido", Id);
        await InvokeAsync(StateHasChanged);
    }

    private async Task MostrarMiUbicacion()
    {
        try
        {
            var permiso = await Permissions.CheckStatusAsync<Permissions.LocationWhenInUse>();

            if (permiso != PermissionStatus.Granted)
                permiso = await Permissions.RequestAsync<Permissions.LocationWhenInUse>();

            if (permiso != PermissionStatus.Granted)
                return;

            var request = new GeolocationRequest(
                GeolocationAccuracy.Best,
                TimeSpan.FromSeconds(10));

            var location = await Geolocation.Default.GetLocationAsync(request);

            if (location is null)
                return;

            await JS.InvokeVoidAsync(
                "mapaRecorrido.mostrarMiUbicacion",
                location.Latitude,
                location.Longitude,
                true);
        }
        catch
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.InvokeAsync("SalirRecorrido", Id);
                await hubConnection.DisposeAsync();
            }
            catch
            {
            }
        }
    }
}