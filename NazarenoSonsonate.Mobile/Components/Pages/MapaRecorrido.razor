@page "/mapa-recorrido/{Id:int}"
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.Devices.Sensors
@using NazarenoSonsonate.Shared.DTOs
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject IJSRuntime JS
@inject HttpClient Http
@implements IAsyncDisposable

<style>
    .map-fullscreen-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #1a051d;
        display: flex;
        flex-direction: column;
        z-index: 1000;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .map-header {
        width: 100%;
        padding: 45px 20px 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 10;
        background-color: #170318;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

    .header-titles {
        display: flex;
        flex-direction: column;
    }

    .main-title {
        font-size: 26px;
        font-family: Georgia, serif;
        font-style: italic;
        color: #fcefd6;
        margin: 0 0 4px 0;
    }

    .subtitle {
        font-size: 11px;
        color: #9d759b;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
    }

    .live-badge {
        font-size: 12px;
        color: #fcefd6;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .map-view {
        flex-grow: 1;
        width: 100%;
        height: 100%;
        position: relative;
    }

    #mapa-recorrido {
        width: 100%;
        height: 100%;
    }

    .status-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: rgba(43, 0, 42, 0.9);
        padding: 20px;
        border-radius: 12px;
        color: #fcefd6;
        text-align: center;
        z-index: 20;
        border: 1px solid rgba(252, 239, 214, 0.2);
    }

    .selector-grupo-bar {
        background: #f3f0eb;
        color: #1b1b1b;
        margin: 0 14px 10px 14px;
        border-radius: 18px;
        padding: 16px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 6px 16px rgba(0,0,0,0.20);
        z-index: 15;
        cursor: pointer;
    }

    .selector-grupo-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 500;
    }

        .selector-grupo-label svg {
            width: 20px;
            height: 20px;
            stroke: #111;
            fill: none;
            stroke-width: 2;
        }

    .selector-grupo-valor {
        font-size: 16px;
        font-weight: 700;
    }

    .grupo-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        z-index: 2000;
        display: flex;
        align-items: flex-end;
    }

    .grupo-modal {
        width: 100%;
        max-height: 82vh;
        background: #f7f7f7;
        border-radius: 24px 24px 0 0;
        overflow-y: auto;
        padding: 14px 0 30px 0;
    }

    .grupo-modal-handle {
        width: 52px;
        height: 5px;
        border-radius: 999px;
        background: #c9c9c9;
        margin: 0 auto 12px auto;
    }

    .grupo-item {
        padding: 20px 26px;
        font-size: 22px;
        color: #111;
        border-bottom: 1px solid #e8e8e8;
        cursor: pointer;
    }

        .grupo-item.selected {
            background: #efe6f7;
            color: #6A1B9A;
            font-weight: 700;
        }

    .bottom-nav {
        background-color: #170318;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 5px 25px 5px;
        box-shadow: 0 -5px 20px rgba(0,0,0,0.5);
        z-index: 10;
    }

    .nav-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px 0;
        color: #7a5278;
        cursor: pointer;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .nav-item.active {
            background-color: #3b0939;
            color: #fcefd6;
        }

    .nav-icon {
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .nav-icon svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
        }

    .nav-text {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        text-align: center;
    }
</style>

<div class="map-fullscreen-container">

    <header class="map-header">
        <div class="header-titles">
            <h1 class="main-title">@recorrido?.Nombre</h1>
            <span class="subtitle">@estadoTiempoReal</span>
        </div>
        <div class="live-badge">EN VIVO</div>
    </header>

    <div class="map-view">
        @if (cargando)
        {
            <div class="status-overlay">Cargando recorrido...</div>
        }
        else if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="status-overlay" style="color: #ff6b6b;">@error</div>
        }
        else if (recorrido is null)
        {
            <div class="status-overlay">No se encontró el recorrido.</div>
        }
        else if (string.IsNullOrWhiteSpace(recorrido.RutaGeoJson))
        {
            <div class="status-overlay">Recorrido pendiente de publicación.</div>
        }
        else
        {
            <div id="mapa-recorrido"></div>
        }
    </div>

    @if (filtroActivo == "grupo" && !string.IsNullOrWhiteSpace(tipoSelectorGrupo))
    {
        <div class="selector-grupo-bar" @onclick="AbrirSelectorGrupo">
            <div class="selector-grupo-label">
                <svg viewBox="0 0 24 24">
                    <path d="M3 5h18l-7 8v5l-4 2v-7z"></path>
                </svg>
                <span>
                    Seleccionar número de @(tipoSelectorGrupo == "cargadora" ? "cargadora" : "cargador")
                </span>
            </div>

            <div class="selector-grupo-valor">
                @(string.IsNullOrWhiteSpace(grupoSeleccionadoActual) ? "Seleccionar" : grupoSeleccionadoActual)
            </div>
        </div>
    }

    @if (mostrarSelectorGrupo)
    {
        <div class="grupo-modal-backdrop" @onclick="CerrarSelectorGrupo">
            <div class="grupo-modal" @onclick:stopPropagation="true">
                <div class="grupo-modal-handle"></div>

                @foreach (var grupo in gruposDisponibles)
                {
                    <div class="grupo-item @(grupo == grupoSeleccionadoActual ? "selected" : "")"
                         @onclick="() => SeleccionarGrupo(grupo)">
                        @grupo
                    </div>
                }
            </div>
        </div>
    }

    <nav class="bottom-nav">
        <div class="nav-item @(string.IsNullOrWhiteSpace(filtroActivo) && string.IsNullOrWhiteSpace(tipoSelectorGrupo) ? "active" : "")" @onclick="MostrarProcesion">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"></circle>
                    <circle cx="12" cy="12" r="4" fill="currentColor" stroke="none"></circle>
                </svg>
            </div>
            <span class="nav-text">Procesión</span>
        </div>

        <div class="nav-item" @onclick="MostrarMiUbicacion">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3" fill="currentColor" stroke="none"></circle>
                </svg>
            </div>
            <span class="nav-text">Mi ubicación</span>
        </div>

        <div class="nav-item @(tipoSelectorGrupo == "cargador" ? "active" : "")" @onclick="FiltrarCargadores">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
            </div>
            <span class="nav-text">Cargador</span>
        </div>

        <div class="nav-item @(tipoSelectorGrupo == "cargadora" ? "active" : "")" @onclick="FiltrarCargadoras">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <path d="M12 3a4 4 0 0 0-4 4v1a4 4 0 0 0 8 0V7a4 4 0 0 0-4-4z"></path>
                </svg>
            </div>
            <span class="nav-text">Cargadora</span>
        </div>

        <div class="nav-item @(filtroActivo == "grupo" ? "active" : "")" @onclick="FiltrarGrupo">
            <div class="nav-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M3 5h18l-7 8v5l-4 2v-7z"></path>
                </svg>
            </div>
            <span class="nav-text">Grupos</span>
        </div>
    </nav>

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private RecorridoDto? recorrido;
    private bool cargando = true;
    private string? error;
    private bool mapaDibujado;
    private HubConnection? hubConnection;
    private string estadoTiempoReal = "UBICACIÓN EN VIVO";
    private string filtroActivo = "";
    private bool mostrarSelectorGrupo;
    private List<string> gruposDisponibles = new();
    private string? grupoSeleccionadoActual;
    private string tipoSelectorGrupo = "";

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;
            error = null;
            mapaDibujado = false;
            estadoTiempoReal = "UBICACIÓN EN VIVO";
            filtroActivo = "";
            mostrarSelectorGrupo = false;
            gruposDisponibles = new();
            grupoSeleccionadoActual = null;
            tipoSelectorGrupo = "";

            if (hubConnection is not null)
            {
                await hubConnection.DisposeAsync();
                hubConnection = null;
            }

            recorrido = await RecorridoService.ObtenerRecorridoPorIdAsync(Id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!cargando &&
            !mapaDibujado &&
            recorrido is not null &&
            !string.IsNullOrWhiteSpace(recorrido.RutaGeoJson))
        {
            var puntosJson = JsonSerializer.Serialize(recorrido.PuntosRuta ?? new List<PuntoRutaDto>());

            await JS.InvokeVoidAsync("mapaRecorrido.esperarGoogleMaps");
            await JS.InvokeVoidAsync("mapaRecorrido.init", "mapa-recorrido", 13.7189, -89.7242, 16);
            await JS.InvokeVoidAsync("mapaRecorrido.drawGeoJson", recorrido.RutaGeoJson);
            await JS.InvokeVoidAsync("mapaRecorrido.drawPuntosRuta", puntosJson);

            await IniciarTiempoReal();

            mapaDibujado = true;
        }
    }

    private async Task MostrarProcesion()
    {
        await JS.InvokeVoidAsync("mapaRecorrido.ocultarTodosLosPuntos");

        filtroActivo = "";
        tipoSelectorGrupo = "";
        grupoSeleccionadoActual = null;
        gruposDisponibles.Clear();
        mostrarSelectorGrupo = false;

        StateHasChanged();
    }

    private async Task FiltrarCargadores()
    {
        tipoSelectorGrupo = "cargador";
        filtroActivo = "cargador";
        grupoSeleccionadoActual = null;
        mostrarSelectorGrupo = false;

        await JS.InvokeVoidAsync("mapaRecorrido.filtrarPorTipo", "cargador");

        StateHasChanged();
    }

    private async Task FiltrarCargadoras()
    {
        tipoSelectorGrupo = "cargadora";
        filtroActivo = "cargadora";
        grupoSeleccionadoActual = null;
        mostrarSelectorGrupo = false;

        await JS.InvokeVoidAsync("mapaRecorrido.filtrarPorTipo", "cargadora");

        StateHasChanged();
    }

    private async Task FiltrarGrupo()
    {
        if (string.IsNullOrWhiteSpace(tipoSelectorGrupo))
            return;

        filtroActivo = "grupo";
        await AbrirSelectorGrupo();
    }

    private async Task AbrirSelectorGrupo()
    {
        if (string.IsNullOrWhiteSpace(tipoSelectorGrupo))
            return;

        var grupos = await JS.InvokeAsync<string[]>("mapaRecorrido.obtenerGruposPorTipo", tipoSelectorGrupo);
        gruposDisponibles = new List<string>(grupos ?? Array.Empty<string>());
        mostrarSelectorGrupo = true;
        StateHasChanged();
    }

    private void CerrarSelectorGrupo()
    {
        mostrarSelectorGrupo = false;
        StateHasChanged();
    }

    private async Task SeleccionarGrupo(string grupo)
    {
        grupoSeleccionadoActual = grupo;
        mostrarSelectorGrupo = false;
        filtroActivo = "grupo";

        await JS.InvokeVoidAsync("mapaRecorrido.filtrarPorGrupoYTipo", tipoSelectorGrupo, grupo);

        StateHasChanged();
    }

    private async Task IniciarTiempoReal()
    {
        if (Http.BaseAddress is null)
        {
            estadoTiempoReal = "No se pudo resolver la URL de la API.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var hubUrl = new Uri(Http.BaseAddress, "hubs/procesion");

        hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl.ToString())
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<UbicacionProcesionDto>("UbicacionActualizada", async dto =>
        {
            if (dto.RecorridoId != Id)
                return;

            await JS.InvokeVoidAsync(
                "mapaRecorrido.actualizarMarcadorTiempoReal",
                dto.Latitud,
                dto.Longitud,
                dto.GrupoActual ?? "",
                dto.Mensaje ?? "",
                dto.FechaHora.ToString("g"));
        });

        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("UnirseRecorrido", Id);
        await InvokeAsync(StateHasChanged);
    }

    private async Task MostrarMiUbicacion()
    {
        try
        {
            var permiso = await Permissions.CheckStatusAsync<Permissions.LocationWhenInUse>();

            if (permiso != PermissionStatus.Granted)
                permiso = await Permissions.RequestAsync<Permissions.LocationWhenInUse>();

            if (permiso != PermissionStatus.Granted)
                return;

            var request = new GeolocationRequest(
                GeolocationAccuracy.Best,
                TimeSpan.FromSeconds(10));

            var location = await Geolocation.Default.GetLocationAsync(request);

            if (location is null)
                return;

            await JS.InvokeVoidAsync(
                "mapaRecorrido.mostrarMiUbicacion",
                location.Latitude,
                location.Longitude,
                true);
        }
        catch
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            try
            {
                await hubConnection.InvokeAsync("SalirRecorrido", Id);
                await hubConnection.DisposeAsync();
            }
            catch
            {
            }
        }
    }
}