@page "/mapa-recorrido/{Id:int}"
@using NazarenoSonsonate.Shared.DTOs
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Mapa del recorrido</h3>

@if (cargando)
{
    <p>Cargando información del recorrido...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:red;">@error</p>
}
else if (recorrido is null)
{
    <p>No se encontró el recorrido.</p>
}
else
{
    <div class="card p-3 mb-3">
        <h4>@recorrido.Nombre</h4>
        <p>@recorrido.Descripcion</p>
        <p><strong>Hora de salida:</strong> @recorrido.HoraSalida</p>
    </div>

    @if (ubicacionActual is not null)
    {
        <div class="card p-3 mb-3">
            <h5>Ubicación actual</h5>
            <p><strong>Latitud:</strong> @ubicacionActual.Latitud</p>
            <p><strong>Longitud:</strong> @ubicacionActual.Longitud</p>
            <p><strong>Grupo actual:</strong> @ubicacionActual.GrupoActual</p>
            <p><strong>Mensaje:</strong> @ubicacionActual.Mensaje</p>
            <p><strong>Actualizado:</strong> @ubicacionActual.FechaHora.ToString("dd/MM/yyyy hh:mm tt")</p>
        </div>
    }

    <div class="card p-3">
        <h5>Puntos de ruta</h5>
        <ul>
            @foreach (var punto in recorrido.PuntosRuta.OrderBy(x => x.Orden))
            {
                <li>
                    Punto @punto.Orden - Lat: @punto.Latitud, Lng: @punto.Longitud
                    @if (!string.IsNullOrWhiteSpace(punto.Referencia))
                    {
                        <span>- @punto.Referencia</span>
                    }
                </li>
            }
        </ul>
    </div>

    <button class="btn btn-secondary mt-3" @onclick="Volver">Volver</button>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private RecorridoDto? recorrido;
    private UbicacionProcesionDto? ubicacionActual;
    private bool cargando = true;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;
            error = null;

            recorrido = await RecorridoService.ObtenerRecorridoPorIdAsync(Id);
            ubicacionActual = await Http.GetFromJsonAsync<UbicacionProcesionDto>($"api/ubicacion/{Id}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/recorridos");
    }
}