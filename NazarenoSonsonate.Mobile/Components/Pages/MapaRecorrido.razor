@page "/mapa-recorrido/{Id:int}"
@using Microsoft.JSInterop
@using NazarenoSonsonate.Shared.DTOs
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h3>Detalle del recorrido</h3>

@if (cargando)
{
    <p>Cargando recorrido...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:red;">@error</p>
}
else if (recorrido is null)
{
    <p>No se encontró el recorrido.</p>
}
else
{
    <div class="card p-3 mb-3">
        <h4>@recorrido.Nombre</h4>
        <p>@recorrido.Descripcion</p>
        <p><strong>Hora de salida:</strong> @recorrido.HoraSalida</p>
    </div>

    <div id="mapa-recorrido" style="height: 450px; width: 100%; border-radius: 12px;"></div>

    <div class="card p-3 mt-3">
        <h5>Puntos de referencia</h5>
        <ol>
            @foreach (var punto in recorrido.PuntosRuta.OrderBy(x => x.Orden))
            {
                <li>@punto.Referencia</li>
            }
        </ol>
    </div>

    <button class="btn btn-secondary mt-3" @onclick="Volver">Volver</button>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private RecorridoDto? recorrido;
    private bool cargando = true;
    private string? error;
    private bool mapaDibujado;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            cargando = true;
            error = null;
            mapaDibujado = false;

            recorrido = await RecorridoService.ObtenerRecorridoPorIdAsync(Id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!cargando && !mapaDibujado && recorrido is not null && recorrido.PuntosRuta.Any())
        {
            var puntosOrdenados = recorrido.PuntosRuta.OrderBy(x => x.Orden).ToList();
            var primerPunto = puntosOrdenados.First();

            await JS.InvokeVoidAsync("mapaRecorrido.init", "mapa-recorrido", primerPunto.Latitud, primerPunto.Longitud, 16);

            var puntos = puntosOrdenados.Select(x => new
            {
                orden = x.Orden,
                referencia = x.Referencia,
                latitud = x.Latitud,
                longitud = x.Longitud
            });

            await JS.InvokeVoidAsync("mapaRecorrido.drawRoute", puntos);

            mapaDibujado = true;
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/recorridos");
    }
}