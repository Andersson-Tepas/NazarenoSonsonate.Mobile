@page "/recorridos"
@using NazarenoSonsonate.Shared.DTOs
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject NavigationManager Navigation

<h2 class="titulo-pagina">Recorridos procesionales</h2>

@if (cargando)
{
    <p style="color:white;">Cargando recorridos...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:red;">@error</p>
}
else if (recorridos.Count == 0)
{
    <p style="color:white;">No hay recorridos disponibles.</p>
}
else
{
    <div style="display:flex; flex-direction:column; gap:15px;">

        @foreach (var recorrido in recorridos)
        {
            <div class="recorrido-card">

                <div class="titulo-recorrido">@recorrido.Nombre</div>

                <div class="descripcion">
                    @recorrido.Descripcion
                </div>

                <div class="hora">
                    Hora de salida: @recorrido.HoraSalida
                </div>

                <div class="botones">

                    <button class="btn-detalle"
                            @onclick="() => AbrirRecorrido(recorrido.Id)">
                        Ver detalle
                    </button>

                    <button class="btn-mapa"
                            @onclick="() => AbrirEditorAdmin(recorrido.Id)">
                        Mapa
                    </button>

                </div>

            </div>
        }

    </div>
}

@code {
    private List<RecorridoDto> recorridos = new();
    private bool cargando = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recorridos = await RecorridoService.ObtenerRecorridosAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private void AbrirRecorrido(int id)
    {
        Navigation.NavigateTo($"/mapa-recorrido/{id}");
    }

    private void AbrirEditorAdmin(int id)
    {
        Navigation.NavigateTo($"/admin/recorrido-editor/{id}");
    }
}