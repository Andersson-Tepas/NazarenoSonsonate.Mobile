@page "/recorridos"
@using NazarenoSonsonate.Shared.DTOs
@inject NazarenoSonsonate.Mobile.Services.RecorridoService RecorridoService
@inject NavigationManager Navigation

<style>
    /* Estilos exclusivos para la página de Recorridos */
    .page-title {
        margin-bottom: 30px;
        margin-top: 10px;
    }

    .main-title {
        font-size: 32px;
        font-family: Georgia, serif;
        font-style: italic;
        color: #fcefd6;
        margin-bottom: 5px;
    }

    .subtitle {
        font-size: 14px;
        color: #c085b3;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .cards-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .card-item {
        background-color: #3b0939;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .card-image-header {
        height: 150px;
        background-color: #4a154b;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .card-image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(43, 0, 42, 0.6);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 15px;
    }

    .card-content-box {
        padding: 15px;
    }

    .badge {
        background-color: #7b2cbf;
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 8px;
        align-self: flex-start;
    }

    .day-title {
        font-size: 22px;
        font-family: Georgia, serif;
        font-style: italic;
        color: #fcefd6;
    }

    .description-text {
        font-size: 14px;
        color: #fcefd6;
        margin-bottom: 15px;
        line-height: 1.4;
    }

    .info-row {
        display: flex;
        align-items: center;
        color: #fcefd6;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .icon-clock {
        margin-right: 8px;
        font-size: 16px;
    }

    .button-container {
        display: flex;
        gap: 10px;
    }

    .btn-action-primary {
        background-color: #f7b700;
        color: #2b002a;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: bold;
        font-size: 14px;
        cursor: pointer;
        flex-grow: 1;
        transition: background-color 0.2s;
    }

        .btn-action-primary:hover {
            background-color: #ffd84f;
        }

    .btn-action-icon {
        background-color: transparent;
        border: 1px solid rgba(252, 239, 214, 0.3);
        color: #fcefd6;
        border-radius: 8px;
        padding: 12px;
        width: 45px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s;
    }

        .btn-action-icon:hover {
            background-color: rgba(252, 239, 214, 0.1);
        }
</style>

<div class="page-title">
    <div class="main-title">Jesús Nazareno - Sonsonate</div>
    <div class="subtitle">Recorridos Procesionales 2026-20230</div>
</div>

@if (cargando)
{
    <p style="color:#fcefd6; font-style: italic;">Cargando recorridos...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:#ff6b6b; font-weight: bold;">@error</p>
}
else if (recorridos.Count == 0)
{
    <p style="color:#fcefd6;">No hay recorridos disponibles.</p>
}
else
{
    <div class="cards-container">

        @foreach (var recorrido in recorridos)
        {
            <div class="card-item">

                <div class="card-image-header" style="background-image: url('@ObtenerImagenPorDia(recorrido.Nombre)');">
                    <div class="card-image-overlay">
                        <span class="badge">Solemne</span>
                        <div class="day-title">@recorrido.Nombre</div>
                    </div>
                </div>

                <div class="card-content-box">
                    <div class="description-text">
                        @recorrido.Descripcion
                    </div>

                    <div class="info-row">
                        <span class="icon-clock">&#128337;</span> Salida: @recorrido.HoraSalida
                    </div>

                    <div class="button-container">
                        <button class="btn-action-primary"
                                @onclick="() => AbrirRecorrido(recorrido.Id)">
                            Ver detalle
                        </button>

                        <button class="btn-action-icon" title="Ver Mapa"
                                @onclick="() => AbrirEditorAdmin(recorrido.Id)">
                            &#128205;
                        </button>
                    </div>
                </div>

            </div>
        }

    </div>
}

@code {
    private List<RecorridoDto> recorridos = new();
    private bool cargando = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recorridos = await RecorridoService.ObtenerRecorridosAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private void AbrirRecorrido(int id)
    {
        Navigation.NavigateTo($"/mapa-recorrido/{id}");
    }

    private void AbrirEditorAdmin(int id)
    {
        Navigation.NavigateTo($"/admin/recorrido-editor/{id}");
    }

    // NUEVA FUNCIÓN PARA OBTENER LA IMAGEN
    private string ObtenerImagenPorDia(string nombreRecorrido)
    {
        if (string.IsNullOrWhiteSpace(nombreRecorrido)) return "images/default.jpg";

        var nombre = nombreRecorrido.ToLower();

        if (nombre.Contains("lunes")) return "images/lunes.jpg";
        if (nombre.Contains("martes")) return "images/martes.jpg";
        if (nombre.Contains("miércoles") || nombre.Contains("miercoles")) return "images/miercoles.jpg";
        if (nombre.Contains("jueves")) return "images/jueves.jpg";
        if (nombre.Contains("viernes")) return "images/viernes.jpg";

        return "images/default.jpg";
    }
}